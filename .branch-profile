# Perfil de rama — no editar a mano; regenerar con create-dev-module-branch.sh
branch=dev-pronoun
profile=pronoun
modules=pronoun
sparse_command=./scripts/sparse-module.sh pronoun
cargo_build=cargo build -p api_main --no-default-features --features auth,pronoun_practice
