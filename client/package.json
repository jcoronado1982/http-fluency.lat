{
  "name": "flashcards-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "catalog:generate": "node ../scripts/generate-catalog-manifest.mjs",
    "build": "npm run catalog:generate && vite build",
    "test:routing": "node scripts/test-routing-paths.mjs",
    "test:contracts": "node scripts/test-contracts.mjs",
    "test:deck-usecases": "node scripts/test-deck-use-cases.mjs",
    "test:deck-session": "node scripts/test-deck-session-use-cases.mjs",
    "test:prefetch-cache": "node scripts/test-image-prefetch-cache.mjs",
    "test:bidirectional": "node scripts/test-bidirectional-study.mjs",
    "test:srs": "node scripts/test-srs-engine.mjs",
    "test:pwa": "node scripts/test-pwa.mjs",
    "test": "npm run test:routing && npm run test:contracts && npm run test:deck-usecases && npm run test:deck-session && npm run test:prefetch-cache && npm run test:bidirectional && npm run test:srs && npm run test:pwa",
    "test:components": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=desktop-chromium",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:pwa": "vite preview --host localhost --port 4173 --strictPort"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.1",
    "axios": "^1.16.0",
    "heic2any": "^0.0.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-headroom": "^3.2.1",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.18.0",
    "react-select": "^5.10.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.9.0",
    "globals": "^16.4.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.10",
    "vite": "^8.1.0",
    "vitest": "^4.1.10"
  }
}
