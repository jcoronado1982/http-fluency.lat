# Protección DB sin subprocesos: antes forward_auth → socat → sh (6-8 forks
# POR CADA request, incluidos assets). Ahora Caddy evalúa los mismos archivos
# de estado directamente (como ya se hace con AWS_HEALTHY). Semántica idéntica:
# bloquear ⟺ estado ≠ normal (PROXY_CLOSED existe) y sin permiso del DB (GATE_FILE ausente).
# sentinel-handler/traffic-manager mantienen PROXY_CLOSED ⟺ STATE ≠ normal.
(db_protection) {
    @db_blocked {
        file {
            root /tmp
            try_files PROXY_CLOSED
        }
        not file {
            root /tmp
            try_files GATE_FILE
        }
    }
    handle @db_blocked {
        respond "Service Unavailable" 503
    }
}

# ============================================================
# VÁLVULA DE OVERFLOW: Oracle local → GCP Cloud Run
# /tmp/ORACLE_HEALTHY lo gestiona oracle-ram-monitor.sh (cada 30s):
# existe ⟺ RAM libre del proxy > 250 MB. Bajo picos de usuarios la caja
# de 1 GB desvía el API a Cloud Run (scale-to-zero) en vez de colapsar.
# Cloud Run guarda archivos vía SCP y usa Surreal por WSS (fluency.lat/db).
# ============================================================
(api_with_overflow) {
    @oracle_healthy {
        file {
            root /tmp
            try_files ORACLE_HEALTHY
        }
    }

    handle @oracle_healthy {
        header +X-Backend "Oracle-Local"
        reverse_proxy localhost:8080
    }

    handle {
        header +X-Backend "GCP-Overflow"
        reverse_proxy https://flashcard-backend-977952175712.us-east1.run.app {
            header_up Host {upstream_hostport}
            # Cloud Run ya termina TLS y soporta HTTP/2 nativo (gRPC/h2)
            transport http {
                versions 2 1.1
                tls
            }
        }
    }
}

# ============================================================
# SNIPPET DE COMPRESIÓN: Brotli → zstd → gzip (orden de preferencia)
# Se aplica a todo tipo de contenido comprimible.
# ============================================================
(compression) {
    encode {
        zstd best
        gzip 6
        minimum_length 512
    }
}

theruby.lat {
    handle /rojo* {
        reverse_proxy localhost:8888
    }
    handle /amarillo* {
        reverse_proxy localhost:8888
    }
    handle /normal* {
        reverse_proxy localhost:8888
    }
    handle /status* {
        reverse_proxy localhost:8888
    }

    handle {
        root * /usr/share/caddy/portfolio
        try_files {path} /index.html
        file_server
    }
}

fluency.lat, www.fluency.lat {
    # Exponer SurrealDB de forma segura para los servidores espejo (AWS y Cloud Run)
    handle /db/* {
        uri strip_prefix /db
        reverse_proxy 10.0.1.138:8080
    }

    # Resto de rutas protegidas por el centinela
    handle {
        route {
            import db_protection

            # ------------------------------------------------------------------
            # ASSETS ESTÁTICOS — imágenes y audio (servidos desde disco)
            # ------------------------------------------------------------------
            handle /card_images/* {
                root * /usr/share/caddy/repository

                # Normalizar extensiones legacy → .avif
                @try_avif {
                    path_regexp avif ^(.+)\.(jpg|jpeg|png)$
                }
                rewrite @try_avif {re.avif.1}.avif

                # Misma política que el backend (assets.rs): URL versionada (?v=/?t=)
                # → inmutable 1 año; sin versión → revalidar (304 barato vía ETag).
                # Evita servir imagen vieja tras force_generation (mismo filename).
                @versioned query v=* t=*
                header @versioned Cache-Control "public, max-age=31536000, immutable"
                @unversioned not query v=* t=*
                header @unversioned Cache-Control "public, no-cache"

                header +X-Content-Type-Options "nosniff"
                file_server
            }

            handle /card_audio/* {
                root * /usr/share/caddy/repository
                header Cache-Control "public, max-age=31536000, immutable"
                file_server
            }

            handle /json/* {
                root * /usr/share/caddy/repository
                # browse es requerido: el backend lista directorios parseando este HTML
                import compression
                file_server browse
            }

            # ------------------------------------------------------------------
            # API → backend Oracle local si hay RAM; si no, overflow a GCP
            # ------------------------------------------------------------------
            @backend_routes {
                path /api/*
            }
            handle @backend_routes {
                import compression
                import api_with_overflow
            }

            # ------------------------------------------------------------------
            # FRONTEND ESTÁTICO (SPA)
            # JS/CSS/HTML se versionan con hashes en Vite → cache largo.
            # index.html no se puede cachear agresivamente (es el entry point).
            # ------------------------------------------------------------------
            handle {
                root * /usr/share/caddy/flashcard
                import compression
                try_files {path} /index.html
                file_server
            }
        }
    }
}

